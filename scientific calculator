#include <stdio.h>
#include <math.h>

int main()
{
    int choice;
    double num1, num2, result;

    do
    {
        printf("\n====================================");
        printf("\n      SCIENTIFIC CALCULATOR");
        printf("\n====================================");
        printf("\n1. Addition");
        printf("\n2. Subtraction");
        printf("\n3. Multiplication");
        printf("\n4. Division");
        printf("\n5. Power");
        printf("\n6. Square Root");
        printf("\n7. Sine");
        printf("\n8. Cosine");
        printf("\n9. Tangent");
        printf("\n10. Logarithm (base 10)");
        printf("\n11. Exit");

        printf("\n\nEnter your choice: ");
        scanf("%d", &choice);

        switch(choice)
        {
            case 1:
                printf("Enter two numbers: ");
                scanf("%lf %lf", &num1, &num2);

                result = num1 + num2;

                printf("Result = %.2lf\n", result);
                break;

            case 2:
                printf("Enter two numbers: ");
                scanf("%lf %lf", &num1, &num2);

                result = num1 - num2;

                printf("Result = %.2lf\n", result);
                break;

            case 3:
                printf("Enter two numbers: ");
                scanf("%lf %lf", &num1, &num2);

                result = num1 * num2;

                printf("Result = %.2lf\n", result);
                break;

            case 4:
                printf("Enter two numbers: ");
                scanf("%lf %lf", &num1, &num2);

                if(num2 == 0)
                {
                    printf("Error! Division by zero is not allowed.\n");
                }
                else
                {
                    result = num1 / num2;
                    printf("Result = %.2lf\n", result);
                }
                break;

            case 5:
                printf("Enter base and exponent: ");
                scanf("%lf %lf", &num1, &num2);

                result = pow(num1, num2);

                printf("Result = %.2lf\n", result);
                break;

            case 6:
                printf("Enter a number: ");
                scanf("%lf", &num1);

                if(num1 < 0)
                {
                    printf("Square root of negative number is not possible.\n");
                }
                else
                {
                    result = sqrt(num1);
                    printf("Result = %.2lf\n", result);
                }
                break;

            case 7:
                printf("Enter angle in degrees: ");
                scanf("%lf", &num1);

                result = sin(num1 * 3.14159265 / 180);

                printf("Result = %.4lf\n", result);
                break;

            case 8:
                printf("Enter angle in degrees: ");
                scanf("%lf", &num1);

                result = cos(num1 * 3.14159265 / 180);

                printf("Result = %.4lf\n", result);
                break;

            case 9:
                printf("Enter angle in degrees: ");
                scanf("%lf", &num1);

                result = tan(num1 * 3.14159265 / 180);

                printf("Result = %.4lf\n", result);
                break;

            case 10:
                printf("Enter a number: ");
                scanf("%lf", &num1);

                if(num1 <= 0)
                {
                    printf("Logarithm undefined for zero or negative numbers.\n");
                }
                else
                {
                    result = log10(num1);
                    printf("Result = %.4lf\n", result);
                }
                break;

            case 11:
                printf("Thank you for using the calculator!\n");
                break;

            default:
                printf("Invalid choice! Please try again.\n");
        }

    } while(choice != 11);

    return 0;
}
